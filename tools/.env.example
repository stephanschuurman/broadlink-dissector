# Copy this file to .env and fill in the values.

# Required — obtained by capturing traffic from the BroadLink app
BROADLINK_USER_ID=
BROADLINK_LICENSE_ID=
BROADLINK_COMPANY_ID=

# Optional overrides
BROADLINK_USER_AGENT=BroadLink/1.7.67 (iPad; iOS 26.3; Scale/2.00)
# BCP 47 language tag(s), e.g. "nl-NL;q=1, en-NL;q=0.9"
BROADLINK_ACCEPT_LANGUAGE=en
BROADLINK_API_URL=https://ai-service-eu-001.ibroadlink.com/vtproxy/common
